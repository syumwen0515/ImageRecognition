# 複製此檔案為 .env 並填入實際值

# ── 資料庫 ──────────────────────────────────────────────────────
# SQLite（預設，本地開發用）
DATABASE_URL=sqlite:///./bib_recognition.db

# PostgreSQL（正式環境）
# DATABASE_URL=postgresql://user:password@localhost:5432/bib_recognition

# ── Claude Vision API（最高準確率）────────────────────────────────
# 從 https://console.anthropic.com 取得 API 金鑰
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud Vision API ─────────────────────────────────────
# 下載 Service Account JSON 後設定此路徑
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# ── 上傳設定 ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# ── Cloudinary（雲端圖片儲存，Render 部署用）────────────────────
# 從 https://cloudinary.com/console 取得
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
